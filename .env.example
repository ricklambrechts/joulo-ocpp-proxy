# ── Server ────────────────────────────────────────────────────
PORT=9000

# ── Primary CSMS (required) ──────────────────────────────────
# All charger messages are forwarded here, and all responses
# from this CSMS are relayed back to the charger.
PRIMARY_CSMS_URL=wss://your-primary-csms.example.com/ocpp
# Accept true or false (default: true)
PRIMARY_CSMS_APPEND_CHARGE_POINT_ID=true

# ── Secondary / mirror CSMS (optional) ───────────────────────
# Comma-separated list of additional CSMS endpoints.
# Charger messages are mirrored to these backends, but their
# responses are NOT sent back to the charger.
# SECONDARY_CSMS_URLS=wss://secondary-a.example.com/ocpp,wss://secondary-b.example.com/ocpp
# Accept true or false (default: true)
SECONDARY_CSMS_APPEND_CHARGE_POINT_ID=true

# ── Logging ───────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
